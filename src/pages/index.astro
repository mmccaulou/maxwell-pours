---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const allPosts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Category display labels
const categoryLabels: Record<string, string> = {
  'in-the-glass': 'In the Glass',
  'on-the-floor': 'On the Floor',
  'at-the-table': 'At the Table',
  'off-the-map':  'Off the Map',
  'punch-downs':  'Punch Downs',
};
---

<Base title="Home">

  <!-- =====================================================
       HERO
       Full-bleed full-color photo.
       ===================================================== -->
  <section class="hero">
    <div class="hero__frame">
      <img
        class="hero__img"
        src="/images/munier-at-bubble-bliss.jpeg"
        alt="A glass of white wine on a marble bar in a stone-arched cave"
      />
      <div class="hero__content">
        <h1 class="hero__headline">Honest pours.<br/>No points.</h1>
      </div>
    </div>
  </section>


  <!-- =====================================================
       RECENT POSTS GRID
       Full-color thumbnails on cream. 1 col mobile,
       2–3 col desktop. No floating white cards.
       ===================================================== -->
  <section class="posts-section">
    <div class="container">
      <h2 class="posts-section__heading">Recent Pours</h2>
      <div class="post-grid">
        {allPosts.map((post) => (
          <article class="post-card">
            {post.data.heroImage && (
              <a href={`/posts/${post.id}/`} class="post-card__image-link" tabindex="-1" aria-hidden="true">
                <img
                  src={post.data.heroImage}
                  alt={post.data.title}
                  class="post-card__image"
                  loading="lazy"
                />
              </a>
            )}
            <div class="post-card__body">
              {post.data.category && (
                <span class="tag tag--small">{categoryLabels[post.data.category]}</span>
              )}
              <h3 class="post-card__title">
                <a href={`/posts/${post.id}/`}>{post.data.title}</a>
              </h3>
              {post.data.description && (
                <p class="post-card__desc">{post.data.description}</p>
              )}
              <time class="post-card__date" datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString('en-US', {
                  year: 'numeric', month: 'long', day: 'numeric'
                })}
              </time>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>


  <!-- =====================================================
       NEWSLETTER BAND
       Full-bleed petrol. Placeholder — email service
       will be wired in a later phase.
       ===================================================== -->
  <section class="newsletter">
    <div class="container newsletter__inner">
      <div class="newsletter__copy">
        <h2 class="newsletter__heading">Get the pour delivered.</h2>
        <p class="newsletter__sub">New pours, no noise. Unsubscribe anytime.</p>
      </div>
      <form class="newsletter__form" action="#" method="post">
        <label for="email" class="sr-only">Email address</label>
        <input
          id="email"
          name="email"
          type="email"
          placeholder="your@email.com"
          autocomplete="email"
          required
          class="newsletter__input"
        />
        <button type="submit" class="newsletter__btn">Subscribe</button>
      </form>
    </div>
  </section>

</Base>


<style>
/* ============================================================
   HERO
   ============================================================ */

.hero {
  width: 100%;
}

.hero__frame {
  position: relative;
  width: 100%;
  height: 88svh;
  min-height: 520px;
  max-height: 900px;
}

/* Hero photo fills the frame */
.hero__img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
}

/* Text anchored to the bottom, readable via gradient */
.hero__content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 3rem 1.5rem 2.5rem;
  background: linear-gradient(
    to top,
    rgba(33, 19, 24, 0.72) 0%,
    rgba(33, 19, 24, 0.3) 55%,
    transparent 100%
  );
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 0.875rem;
}

.hero__headline {
  font-family: var(--font-display);
  font-size: clamp(2.5rem, 8vw, 5.5rem);
  font-weight: 800;
  color: var(--lifted-cream);
  line-height: 1.05;
  letter-spacing: -0.02em;
  max-width: 16ch;
}

@media (min-width: 768px) {
  .hero__content {
    padding: 4rem 3rem 3rem;
  }
}


/* ============================================================
   CATEGORY TAG  (reusable across the site)
   ============================================================ */

:global(.tag) {
  display: inline-block;
  font-family: var(--font-body);
  font-size: 0.6875rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--lifted-cream);
  background-color: var(--hot-pink);
  padding: 0.25em 0.65em;
  border-radius: 6px;
  text-decoration: none;
}

:global(.tag--small) {
  font-size: 0.625rem;
}


/* ============================================================
   POST GRID
   ============================================================ */

.posts-section {
  padding-block: 4rem 3rem;
}

.posts-section__heading {
  font-family: var(--font-display);
  font-size: 1rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--muted-ink);
  margin-bottom: 2rem;
  padding-bottom: 0.75rem;
  border-bottom: 1px solid var(--deep-cream);
}

.post-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 3rem;
}

@media (min-width: 640px) {
  .post-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 2.5rem 2rem;
  }
}

@media (min-width: 1024px) {
  .post-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

.post-card {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.post-card__image-link {
  display: block;
  aspect-ratio: 3 / 2;
  overflow: hidden;
  background-color: var(--deep-cream);
}

.post-card__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  transition: transform 0.4s ease;
}
.post-card__image-link:hover .post-card__image {
  transform: scale(1.03);
}

.post-card__body {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 0.4rem;
}

.post-card__title {
  font-family: var(--font-display);
  font-size: clamp(1.125rem, 2.5vw, 1.375rem);
  font-weight: 700;
  line-height: 1.2;
  color: var(--ink);
}

.post-card__title a {
  color: inherit;
  text-decoration: none;
}
.post-card__title a:hover {
  color: var(--cherry);
}

.post-card__desc {
  font-size: 0.9375rem;
  color: var(--muted-ink);
  line-height: 1.55;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  max-width: none;
}

.post-card__date {
  font-size: 0.8125rem;
  color: var(--muted-ink);
  font-family: var(--font-body);
  margin-top: 0.2rem;
}


/* ============================================================
   NEWSLETTER BAND
   ============================================================ */

.newsletter {
  background-color: var(--petrol);
  padding-block: 4rem;
  margin-top: 3rem;
}

.newsletter__inner {
  display: flex;
  flex-direction: column;
  gap: 2rem;
}

@media (min-width: 768px) {
  .newsletter__inner {
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: 3rem;
  }
}

.newsletter__copy { flex: 1; }

.newsletter__heading {
  font-family: var(--font-display);
  font-size: clamp(1.75rem, 4vw, 2.75rem);
  font-weight: 700;
  color: var(--lifted-cream);
  line-height: 1.1;
}

.newsletter__sub {
  font-size: 0.9375rem;
  color: var(--lifted-cream);
  opacity: 0.72;
  margin-top: 0.5rem;
  max-width: none;
}

.newsletter__form {
  display: flex;
  gap: 0;
  flex-shrink: 0;
  width: 100%;
  max-width: 26rem;
}

.newsletter__input {
  flex: 1;
  font-family: var(--font-body);
  font-size: 0.9375rem;
  padding: 0.75rem 1rem;
  border: none;
  border-radius: 6px 0 0 6px;
  background: var(--lifted-cream);
  color: var(--ink);
  outline: none;
}
.newsletter__input::placeholder {
  color: var(--muted-ink);
}

.newsletter__btn {
  font-family: var(--font-body);
  font-size: 0.875rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  padding: 0.75rem 1.25rem;
  background-color: var(--hot-pink);
  color: var(--lifted-cream);
  border: none;
  border-radius: 0 6px 6px 0;
  cursor: pointer;
  transition: background-color 0.18s;
  white-space: nowrap;
}
.newsletter__btn:hover {
  background-color: var(--hot-pink-hover);
}
</style>
