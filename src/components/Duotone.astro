---
/**
 * Duotone — cherry-toned image treatment for hero/title images only.
 * Body images and post-grid thumbnails stay full-color.
 *
 * Usage:
 *   <Duotone src="/images/foo.jpg" alt="Description" />
 *
 * How it works (CSS-only, no JS, no build step):
 *   1. The container's background is set to Cherry.
 *   2. The image is desaturated to grayscale.
 *   3. mix-blend-mode: screen lets the Cherry background bleed through
 *      dark areas while bright areas stay light (cream/ivory).
 *   Result: a genuine two-tone image — Cherry in the shadows,
 *   cream in the highlights — purely in CSS.
 */
interface Props {
  src: string;
  alt: string;
}
const { src, alt } = Astro.props;
---
<div class="duotone">
  <img src={src} alt={alt} />
</div>

<style>
.duotone {
  background-color: var(--cherry);
  overflow: hidden;
  width: 100%;
  height: 100%;
}

.duotone img {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  filter: grayscale(100%) contrast(1.1);
  mix-blend-mode: screen;
  opacity: 0.82;
}
</style>
