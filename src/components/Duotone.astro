---
/**
 * Duotone — two-tone image treatment for hero/title images only.
 * Body images and post-grid thumbnails stay full-color.
 *
 * How it works (CSS-only, no JS):
 *   1. The container background is the shadow color (petrol).
 *   2. The image is desaturated to grayscale.
 *   3. mix-blend-mode: screen lets the petrol show through dark areas
 *      while bright areas stay light (cream/ivory).
 *   Result: petrol in the shadows, lifted cream in the highlights.
 */
interface Props {
  src: string;
  alt: string;
}
const { src, alt } = Astro.props;
---
<div class="duotone">
  <img src={src} alt={alt} />
</div>

<style>
.duotone {
  background-color: var(--petrol);
  overflow: hidden;
  width: 100%;
  height: 100%;
}

.duotone img {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  filter: grayscale(100%) contrast(1.1);
  mix-blend-mode: screen;
  opacity: 0.82;
}
</style>
