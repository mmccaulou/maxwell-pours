---
/**
 * Duotone — petrol-to-cherry image treatment for hero images.
 * The SVG filter definition lives in Base.astro so this component
 * is a clean wrapper with no extra DOM nodes.
 *
 * Dark tones  → Petrol  #0E6E70
 * Light tones → Cherry  #B11E3C
 */
interface Props {
  src: string;
  alt: string;
}
const { src, alt } = Astro.props;
---
<div class="duotone">
  <img src={src} alt={alt} />
</div>

<style>
.duotone {
  overflow: hidden;
  width: 100%;
  height: 100%;
}

.duotone img {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  filter: url(#duotone-petrol-cherry);
}
</style>
