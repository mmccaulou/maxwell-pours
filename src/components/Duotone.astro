---
/**
 * Duotone — petrol-to-cherry image treatment for hero images.
 *
 * Uses an SVG feColorMatrix filter for a precise two-color duotone:
 *   Dark tones  → Petrol  #0E6E70
 *   Light tones → Cherry  #B11E3C
 *
 * The math: after converting to grayscale (v = 0–1),
 *   R_out = 0.639v + 0.055   (0 → petrol R, 1 → cherry R)
 *   G_out = −0.313v + 0.431  (0 → petrol G, 1 → cherry G)
 *   B_out = −0.204v + 0.439  (0 → petrol B, 1 → cherry B)
 */
interface Props {
  src: string;
  alt: string;
}
const { src, alt } = Astro.props;
---

<!-- Zero-size SVG holds the filter definition — invisible, not announced to screen readers -->
<svg
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
  focusable="false"
  style="position:absolute;width:0;height:0;overflow:hidden"
>
  <defs>
    <filter id="duotone-petrol-cherry" color-interpolation-filters="sRGB">
      <feColorMatrix type="saturate" values="0" result="gray" />
      <feColorMatrix
        type="matrix"
        in="gray"
        values=" 0.639  0  0  0  0.055
                -0.313  0  0  0  0.431
                -0.204  0  0  0  0.439
                 0      0  0  1  0"
      />
    </filter>
  </defs>
</svg>

<div class="duotone">
  <img src={src} alt={alt} />
</div>

<style>
.duotone {
  overflow: hidden;
  width: 100%;
  height: 100%;
}

.duotone img {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  filter: url(#duotone-petrol-cherry);
}
</style>
