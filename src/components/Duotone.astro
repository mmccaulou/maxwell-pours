---
/**
 * Duotone — CSS blend mode image treatment for hero images.
 * Petrol background + screen blend = petrol in shadows, cream in highlights.
 */
interface Props {
  src: string;
  alt: string;
}
const { src, alt } = Astro.props;
---
<div class="duotone">
  <img src={src} alt={alt} />
</div>

<style>
.duotone {
  background-color: var(--petrol);
  overflow: hidden;
  width: 100%;
  height: 100%;
}

.duotone img {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  filter: grayscale(100%) contrast(1.1);
  mix-blend-mode: screen;
  opacity: 0.82;
}
</style>
