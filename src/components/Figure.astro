---
/**
 * Figure — body image with optional caption.
 *
 * Props:
 *   src      — path from /images/… (required)
 *   alt      — describe what is in the photo (required, for accessibility)
 *   layout   — 'inset' | 'full-bleed' | 'float-left' | 'float-right'
 *              defaults to 'inset'
 *   label    — short hot-pink ALL-CAPS label above the caption  (optional)
 *   caption  — one-line description in muted ink below the label (optional)
 */

interface Props {
  src: string;
  alt: string;
  layout?: 'inset' | 'full-bleed' | 'float-left' | 'float-right';
  aspect?: string;   // e.g. "16/9", "4/3", "1/1" — omit to use photo's natural ratio
  label?: string;
  caption?: string;
}

const { src, alt, layout = 'inset', aspect, label, caption } = Astro.props;
---

<figure
  class={`fig fig--${layout}`}
  style={(layout === 'float-left' || layout === 'float-right')
    ? 'margin-top: 0.25rem; margin-bottom: 0.5rem; max-width: var(--float-max-w, 20rem);'
    : undefined}
>
  <img
    src={src}
    alt={alt}
    loading="lazy"
    decoding="async"
    style={aspect ? `aspect-ratio:${aspect};object-fit:cover;width:100%;` : undefined}
  />
  {(label || caption) && (
    <figcaption>
      {label  && <span class="fig__label">{label}</span>}
      {caption && <span class="fig__caption">{caption}</span>}
    </figcaption>
  )}
</figure>

<style>
/* ---- Base -------------------------------------------------- */
.fig {
  margin-block: 2.25rem;
  margin-inline: 0;
}

.fig img {
  width: 100%;
  height: auto;
  display: block;
}

.fig figcaption {
  display: flex;
  flex-direction: column;
  gap: 0.15rem;
  margin-top: 0.5rem;
}

.fig__label {
  font-family: var(--font-body);
  font-size: 0.625rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--hot-pink);
}

.fig__caption {
  font-family: var(--font-body);
  font-size: 0.8125rem;
  line-height: 1.5;
  color: var(--muted-ink);
}

/* ---- INSET (default) — text-column width, no override needed */

/* ---- FULL-BLEED — breaks the prose column ---- */
.fig--full-bleed {
  margin-inline: calc(-1 * var(--gap, 1.5rem));
}

@media (min-width: 768px) {
  .fig--full-bleed {
    margin-inline: -10vw;
  }
}

/*
 * FLOAT MARGINS — DO NOT move these to CSS.
 * The base .fig rule uses margin-block (logical property) which shares the
 * same specificity as .fig--float-* after Astro's scope attribute is applied.
 * CSS changes here have no reliable effect. Margins are set via inline style
 * on the <figure> element instead, where inline always wins the cascade.
 * Current values: margin-top 0.25rem (aligns photo top with adjacent paragraph),
 * margin-bottom 0.5rem (tightens text wrap below caption).
 */

/* ---- FLOAT LEFT ---- */
.fig--float-left {
  float: left;
  width: 40%;
  margin-top: 0.25rem;
  margin-right: 2rem;
  margin-bottom: 0.5rem;
  margin-left: 0;
  clear: left;
}

/* ---- FLOAT RIGHT ---- */
.fig--float-right {
  float: right;
  width: 40%;
  margin-top: 0.25rem;
  margin-left: 2rem;
  margin-bottom: 0.5rem;
  margin-right: 0;
  clear: right;
}

/* ---- MOBILE: every layout goes full-width ---- */
@media (max-width: 639px) {
  .fig--float-left,
  .fig--float-right {
    float: none;
    width: 100%;
    margin-inline: 0;
    --float-max-w: none;  /* overrides the inline style's custom property */
  }

  .fig--full-bleed {
    margin-inline: calc(-1 * var(--gap, 1.5rem));
  }
}
</style>
