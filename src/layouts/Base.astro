---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Let\'s get into wine worth drinking.' } = Astro.props;

const nav = [
  { label: 'In the Glass',  href: '/category/in-the-glass/' },
  { label: 'On the Floor',  href: '/category/on-the-floor/' },
  { label: 'At the Table',  href: '/category/at-the-table/' },
  { label: 'Off the Map',   href: '/category/off-the-map/'  },
  { label: 'Punch Downs',   href: '/category/punch-downs/'  },
];

const currentPath = Astro.url.pathname;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <title>{title === 'Home' ? 'Maxwell Pours' : `${title} | Maxwell Pours`}</title>
  <!-- Favicons -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />

  <!-- Fonts: Fraunces (display) + DM Sans (body) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,300..900&family=DM+Sans:ital,opsz,wght@0,9..40,300..700;1,9..40,300..700&display=swap"
    rel="stylesheet"
  />
</head>
<body>

  <!-- ======================================================
       MASTHEAD
       Petrol background. Wordmark + tagline + 5-item nav.
       Mobile: nav collapses behind a hamburger (CSS-only, no JS).
       ====================================================== -->
  <header class="masthead">
    <div class="masthead__inner container">

      <div class="masthead__brand">
        <a href="/" class="wordmark">Maxwell Pours</a>
        <p class="tagline">Let's get into wine worth drinking</p>
      </div>

      <!-- CSS-only mobile toggle: input must sit before the nav in DOM -->
      <input type="checkbox" id="nav-toggle" class="nav-toggle" aria-hidden="true" />
      <label for="nav-toggle" class="nav-label" aria-label="Toggle navigation">
        <!-- Hamburger icon (shown when nav is closed) -->
        <svg class="nav-icon nav-icon--open" width="24" height="24" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="3" y1="6"  x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
        <!-- Close icon (shown when nav is open) -->
        <svg class="nav-icon nav-icon--close" width="24" height="24" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="4"  y1="4"  x2="20" y2="20"/>
          <line x1="20" y1="4"  x2="4"  y2="20"/>
        </svg>
      </label>

      <nav class="site-nav" aria-label="Main navigation">
        <ul>
          {nav.map(({ label, href }) => (
            <li>
              <a href={href} class={currentPath.startsWith(href) ? 'is-active' : ''}>
                {label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

    </div>
  </header>

  <!-- ====================================================== -->
  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container">
      <p class="site-footer__copy">
        &copy; {new Date().getFullYear()} Maxwell Pours
      </p>
      <p class="site-footer__address">
        6523 California Ave SW, Suite 122, Seattle, WA 98136
      </p>
    </div>
  </footer>

  <script>
    (function () {
      const masthead = document.querySelector('.masthead');
      if (!masthead) return;
      let lastY = window.scrollY;

      window.addEventListener('scroll', function () {
        const y = window.scrollY;
        if (y > 72) {
          if (y > lastY) {
            masthead.classList.add('masthead--compact');
          } else {
            masthead.classList.remove('masthead--compact');
          }
        } else {
          masthead.classList.remove('masthead--compact');
        }
        lastY = y;
      }, { passive: true });
    })();
  </script>
</body>
</html>

<style>
/* ============================================================
   MASTHEAD STYLES
   ============================================================ */

.masthead {
  background-color: var(--petrol);
  color: var(--lifted-cream);
  position: sticky;
  top: 0;
  z-index: 100;
}

.masthead__inner {
  padding-block: 1.5rem 1.25rem;
  transition: padding 0.25s ease;
  display: grid;
  grid-template-areas:
    "brand toggle"
    "nav   nav";
  grid-template-columns: 1fr auto;
  align-items: start;
  column-gap: 1rem;
}

/* --- Wordmark & tagline ------------------------------------ */

.masthead__brand { grid-area: brand; }

.wordmark {
  font-family: var(--font-display);
  font-size: clamp(2rem, 6vw, 3.25rem);
  font-weight: 800;
  color: var(--hot-pink);
  text-decoration: none;
  line-height: 1;
  display: block;
  letter-spacing: -0.02em;
}
.wordmark:hover { color: var(--hot-pink); opacity: 0.88; }

.tagline {
  font-family: var(--font-body);
  font-size: 0.8125rem;
  color: var(--lifted-cream);
  margin-top: 0.25rem;
  letter-spacing: 0.01em;
  max-height: 2rem;
  overflow: hidden;
  opacity: 1;
  transition: max-height 0.25s ease, opacity 0.2s ease, margin-top 0.25s ease;
}

/* --- Compact state (scrolling down) ------------------------ */

.masthead--compact .masthead__inner {
  padding-block: 0.4rem 0.4rem;
  align-items: center;
}

.masthead--compact .tagline {
  max-height: 0;
  opacity: 0;
  margin-top: 0;
}

/* Mobile: also collapse the open nav when going compact */
.masthead--compact .nav-toggle:not(:checked) ~ .site-nav {
  max-height: 0;
}

@media (min-width: 768px) {
  .masthead--compact .masthead__inner {
    padding-block: 0.625rem 0;
  }
  /* Keep nav visible on desktop compact, just tighten spacing */
  .masthead--compact .site-nav {
    margin-top: 0.5rem;
  }
}

/* --- Mobile hamburger toggle ------------------------------- */

.nav-toggle { display: none; }   /* hidden input drives state */

.nav-label {
  grid-area: toggle;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  color: var(--lifted-cream);
  padding: 0.5rem;
  margin-top: 0.25rem;
}

.nav-icon--close { display: none; }

/* When checkbox is checked: swap icons */
.nav-toggle:checked ~ .nav-label .nav-icon--open  { display: none; }
.nav-toggle:checked ~ .nav-label .nav-icon--close { display: block; }

/* --- Nav --------------------------------------------------- */

.site-nav {
  grid-area: nav;
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.28s ease;
}

/* Nav open on mobile */
.nav-toggle:checked ~ .site-nav {
  max-height: 24rem;
}

.site-nav ul {
  display: flex;
  flex-direction: column;
  padding-block: 0;
  border-top: 1px solid rgba(250, 243, 229, 0.18);
  margin-top: 1rem;
}

.site-nav a {
  display: block;
  font-family: var(--font-body);
  font-size: 0.9375rem;
  font-weight: 500;
  color: var(--lifted-cream);
  text-decoration: none;
  padding-block: 0.625rem;
  border-bottom: 1px solid rgba(250, 243, 229, 0.12);
  letter-spacing: 0.01em;
  transition: color 0.18s;
}
.site-nav a:hover { color: var(--hot-pink); }
.site-nav a.is-active { color: var(--cherry); }
.site-nav li:last-child a { border-bottom: none; }

/* --- Desktop ----------------------------------------------- */

@media (min-width: 768px) {
  .masthead__inner {
    grid-template-areas:
      "brand"
      "nav";
    grid-template-columns: 1fr;
    justify-items: center;
    padding-block-end: 0;
  }

  .masthead__brand { text-align: center; }

  .nav-label { display: none; }   /* hide hamburger */

  .site-nav {
    max-height: none !important;   /* always visible */
    overflow: visible;
    width: 95%;
    margin-inline: auto;
    border-top: 1px solid rgba(250, 243, 229, 0.18);
    margin-top: 1rem;
  }

  .site-nav ul {
    flex-direction: row;
    gap: 2rem;
    padding-block: 0.75rem;
    margin-top: 0;
    border-top: none;
    justify-content: center;
  }

  .site-nav a {
    padding-block: 0;
    border-bottom: none;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
}


/* ============================================================
   FOOTER
   ============================================================ */

.site-footer {
  background-color: var(--deep-cream);
  border-top: 1px solid var(--deep-cream);
  padding-block: 2rem;
  margin-top: 4rem;
}

.site-footer__copy {
  font-family: var(--font-body);
  font-size: 0.8125rem;
  color: var(--muted-ink);
  max-width: none;
}

.site-footer__address {
  font-family: var(--font-body);
  font-size: 0.75rem;
  color: var(--muted-ink);
  opacity: 0.7;
  margin-top: 0.375rem;
  max-width: none;
}
</style>
