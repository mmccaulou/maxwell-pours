---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Let\'s get into wine worth drinking.' } = Astro.props;

const nav = [
  { label: 'In the Glass',  href: '/category/in-the-glass/' },
  { label: 'On the Floor',  href: '/category/on-the-floor/' },
  { label: 'At the Table',  href: '/category/at-the-table/' },
  { label: 'Off the Map',   href: '/category/off-the-map/'  },
  { label: 'Punch Downs',   href: '/category/punch-downs/'  },
];

const currentPath = Astro.url.pathname;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <title>{title === 'Home' ? 'Maxwell Pours' : `${title} | Maxwell Pours`}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Fonts: Fraunces (display) + DM Sans (body) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,300..900&family=DM+Sans:ital,opsz,wght@0,9..40,300..700;1,9..40,300..700&display=swap"
    rel="stylesheet"
  />
</head>
<body>

  <!-- ======================================================
       MASTHEAD — two bands
       Top band:    Petrol — wordmark + tagline
       Bottom band: Cherry — five nav items
       Mobile: cherry band collapses; hamburger lives in petrol band.
       CSS-only toggle: input must be the first child of header
       so the ~ sibling selector can reach both bands.
       ====================================================== -->
  <header class="masthead">

    <!-- Hidden checkbox drives the mobile toggle (no JS) -->
    <input type="checkbox" id="nav-toggle" class="nav-toggle" aria-hidden="true" />

    <!-- PETROL BAND -->
    <div class="masthead__brand-band">
      <div class="container masthead__brand-inner">
        <div class="masthead__brand">
          <a href="/" class="wordmark">Maxwell Pours</a>
          <p class="tagline">Let's get into wine worth drinking</p>
        </div>
        <!-- Hamburger lives in the petrol band on mobile -->
        <label for="nav-toggle" class="nav-label" aria-label="Toggle navigation">
          <svg class="nav-icon nav-icon--open" width="24" height="24" viewBox="0 0 24 24"
               fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <line x1="3" y1="6"  x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
          <svg class="nav-icon nav-icon--close" width="24" height="24" viewBox="0 0 24 24"
               fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <line x1="4"  y1="4"  x2="20" y2="20"/>
            <line x1="20" y1="4"  x2="4"  y2="20"/>
          </svg>
        </label>
      </div>
    </div>

    <!-- CHERRY BAND -->
    <div class="masthead__nav-band">
      <div class="container">
        <nav class="site-nav" aria-label="Main navigation">
          <ul>
            {nav.map(({ label, href }) => (
              <li>
                <a href={href} class={currentPath.startsWith(href) ? 'is-active' : ''}>
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </div>

  </header>

  <!-- ====================================================== -->
  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container">
      <p class="site-footer__copy">
        &copy; {new Date().getFullYear()} Maxwell Pours
      </p>
    </div>
  </footer>

</body>
</html>

<style>
/* ============================================================
   MASTHEAD
   ============================================================ */

.masthead {
  position: relative;   /* stacking context for absolute children if needed */
}

.nav-toggle { display: none; }   /* hidden checkbox drives mobile state */


/* --- PETROL BAND (wordmark + tagline) ---------------------- */

.masthead__brand-band {
  background-color: var(--petrol);
  color: var(--lifted-cream);
}

.masthead__brand-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-block: 1.25rem;
}

.masthead__brand { flex: 1; }

.wordmark {
  font-family: var(--font-display);
  font-size: clamp(2rem, 6vw, 3.25rem);
  font-weight: 800;
  color: var(--lifted-cream);
  text-decoration: none;
  line-height: 1;
  display: block;
  letter-spacing: -0.02em;
}
.wordmark:hover { opacity: 0.88; color: var(--lifted-cream); }

.tagline {
  font-family: var(--font-body);
  font-size: 0.8125rem;
  color: var(--hot-pink);
  margin-top: 0.375rem;
  font-style: italic;
  letter-spacing: 0.01em;
}


/* --- Mobile hamburger -------------------------------------- */

.nav-label {
  display: flex;
  align-items: center;
  cursor: pointer;
  color: var(--lifted-cream);
  padding: 0.5rem;
  flex-shrink: 0;
}

.nav-icon--close { display: none; }

/* Swap icons when nav is open */
.nav-toggle:checked ~ .masthead__brand-band .nav-icon--open  { display: none; }
.nav-toggle:checked ~ .masthead__brand-band .nav-icon--close { display: block; }


/* --- CHERRY BAND (nav) ------------------------------------- */

.masthead__nav-band {
  background-color: var(--cherry);
}

/* Mobile: nav band collapses */
.masthead__nav-band {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.28s ease;
}

.nav-toggle:checked ~ .masthead__nav-band {
  max-height: 24rem;
}

.site-nav ul {
  display: flex;
  flex-direction: column;
  padding-block: 0.5rem;
}

.site-nav a {
  display: block;
  font-family: var(--font-body);
  font-size: 0.9375rem;
  font-weight: 500;
  color: var(--lifted-cream);
  text-decoration: none;
  padding-block: 0.625rem;
  border-bottom: 1px solid rgba(250, 243, 229, 0.15);
  letter-spacing: 0.01em;
  transition: color 0.18s;
}
.site-nav a:hover   { color: var(--hot-pink); }
.site-nav a.is-active {
  color: var(--lifted-cream);
  text-decoration: underline;
  text-decoration-color: var(--hot-pink);
  text-underline-offset: 4px;
  text-decoration-thickness: 2px;
}


/* --- Desktop ----------------------------------------------- */

@media (min-width: 768px) {
  .nav-label { display: none; }   /* hide hamburger */

  .masthead__nav-band {
    max-height: none !important;
    overflow: visible;
  }

  .site-nav ul {
    flex-direction: row;
    gap: 2rem;
    padding-block: 0.75rem;
  }

  .site-nav a {
    padding-block: 0;
    border-bottom: none;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
}


/* ============================================================
   FOOTER
   ============================================================ */

.site-footer {
  background-color: var(--deep-cream);
  border-top: 1px solid var(--deep-cream);
  padding-block: 2rem;
  margin-top: 4rem;
}

.site-footer__copy {
  font-family: var(--font-body);
  font-size: 0.8125rem;
  color: var(--muted-ink);
  max-width: none;
}
</style>
