---
import Base from './Base.astro';

interface Props {
  title: string;
  description?: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
}

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---
<Base title={title} description={description}>
  <article>
    {heroImage && <img src={heroImage} alt={title} style="max-width:100%;height:auto;" />}
    <h1>{title}</h1>
    <time datetime={pubDate.toISOString()}>
      {pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
    </time>
    {updatedDate && (
      <p>Updated: <time datetime={updatedDate.toISOString()}>{updatedDate.toLocaleDateString()}</time></p>
    )}
    <slot />
  </article>
</Base>
